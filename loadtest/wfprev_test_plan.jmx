                  <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
                    <stringProp name="scriptLanguage">groovy</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">import org.apache.jmeter.services.FileServer;

def threadNum=ctx.getThreadNum();

String currDir = &quot;C:\\jmeter&quot;
//String currDir = vars.get(&quot;currDir&quot;)

String csvFile = new File(currDir + &apos;\\users.csv&apos;).text;
String[] credentialList = csvFile.split(&apos;\n&apos;);
//String[] credential = credentialList[3].split(&apos;,&apos;);
String[] credential = credentialList[threadNum % (credentialList.size())].split(&apos;,&apos;);


log.info(&quot;Thread &quot; + ctx.getThreadNum().toString() + &quot; of &quot; + credentialList.size().toString());
vars.putObject(&quot;firstRun&quot;,false)

vars.put(&quot;username&quot;,credential[0]); 
vars.put(&quot;password&quot;,credential[1]);</stringProp>
                  </JSR223PreProcessor>
