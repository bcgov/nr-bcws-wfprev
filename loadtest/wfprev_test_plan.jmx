          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Random Value Generator" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import org.apache.jmeter.services.FileServer;
import org.apache.commons.lang3.RandomUtils;

def threadNum=ctx.getThreadNum();

String currDir = vars.get(&quot;currDir&quot;)

String csvFile = new File(currDir + &apos;\\stringFrags.csv&apos;).text;
String[] stringFrags = csvFile.split(&apos;,&apos;);
String[] FireCenterCode = [&quot;2&quot;, &quot;8&quot;, &quot;25&quot;, &quot;34&quot;, &quot;42&quot;, &quot;50&quot;]
String[] activityCategoryCode = [&quot;RX_DEV&quot;, &quot;FL_MGMT_PL&quot;, &quot;WUIWRRPLAN&quot;, &quot;OPER_TREAT&quot;, &quot;MNT_SURVEY&quot;, &quot;MNT_OP_TRT&quot;, &quot;OTH_ASSSRV&quot;, &quot;OTH_ADMIN&quot;, &quot;PLN_DEV&quot;, &quot;COORD&quot;, &quot;IMPL_DELIV&quot;, &quot;MON_MAINT&quot;]
String[] objectiveCategoryCode = [&quot;WRR&quot;,&quot;CRIT_INFRA&quot;,&quot;ECO_REST&quot;,&quot;EGRSS_EVAC&quot;,&quot;FOR_HEALTH&quot;,&quot;HAZ_ABATE&quot;,&quot;RNG_HAB_MG&quot;,&quot;RECONCIL&quot;,&quot;WLD_HAB_MG&quot;,&quot;OTHER&quot;]

Integer random50 = RandomUtils.nextInt(0,49)
Integer random10 = RandomUtils.nextInt(0,10)

vars.put(&quot;yearVar&quot;, RandomUtils.nextInt(2021,2026).toString())
vars.put(&quot;stringFrag&quot;,stringFrags[random50]);
vars.put(&quot;randomFireCenter&quot;,FireCenterCode[RandomUtils.nextInt(0,6)])
vars.put(&quot;randomActivityCategoryCode&quot;,activityCategoryCode[RandomUtils.nextInt(0,12)])
vars.put(&quot;randomObjectiveCategoryCode&quot;,objectiveCategoryCode[random10])
vars.put(&quot;randomSecondaryObjectiveCategoryCode&quot;,objectiveCategoryCode[(random10 + RandomUtils.nextInt(1,10)) % 10])</stringProp>
          </JSR223PreProcessor>
